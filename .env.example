# CampusMarket Environment Configuration
# Copy this file to .env and fill in your values

# ---------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------
# If using Supabase or Postgres, set the full URL here:
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Alternatively, configure connection parameters individually:
# DB_TYPE=pgsql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASS=

# ---------------------------------------------------------
# Supabase Configuration
# ---------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ---------------------------------------------------------
# Resend Mailer Configuration
# ---------------------------------------------------------
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_NAME=CampusMarket
RESEND_FROM_EMAIL=noreply@campusmarketplace.site

# Where support requests / reports should be delivered
SUPPORT_EMAIL=support@campusmarketplace.site

# ---------------------------------------------------------
# Google Cloud Translation API (for message translation)
# ---------------------------------------------------------
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# ---------------------------------------------------------
# Web Push (VAPID) - for background browser notifications
# ---------------------------------------------------------
# Generate once and store securely.
# Generate once: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=your_base64url_vapid_public_key
WEB_PUSH_PRIVATE_KEY=your_base64url_vapid_private_key
WEB_PUSH_SUBJECT=mailto:support@campusmarketplace.site

# Internal auth for server-side web push sender (Vercel function).
# Required on Vercel for system notifications when the app is closed.
INTERNAL_PUSH_KEY=change_me_to_a_long_random_string

# Signs the stateless session cookie (server-only). Use a long random string.
# If omitted, INTERNAL_PUSH_KEY is used as a fallback.
SESSION_STATELESS_SECRET=change_me_to_another_long_random_string

# ---------------------------------------------------------
# Stripe Configuration
# ---------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
# From Stripe Dashboard → Developers → Webhooks (checkout.session.completed)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

GEMINI_API_KEY=your_gemini_api_key_here
OPEN_ROUTER_API_KEY=your_open_router_api_key_here
CHATBOT_GEMINI_API_KEY=your_chatbot_gemini_api_key_here
# Also set GEMINI_API_KEY (or CHATBOT_GEMINI_API_KEY) in Supabase Dashboard →
# Project Settings → Edge Functions → Secrets for the chatbot function.