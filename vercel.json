{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "includeFiles": "**/*.php"
    }
  },
  "routes": [
    {
      "src": "/public/css/(.*)",
      "headers": { "Content-Type": "text/css", "Cache-Control": "public, max-age=31536000" },
      "dest": "/public/css/$1"
    },
    {
      "src": "/public/js/(.*)",
      "headers": { "Content-Type": "application/javascript", "Cache-Control": "public, max-age=31536000" },
      "dest": "/public/js/$1"
    },
    {
      "src": "/public/images/(.*)",
      "dest": "/public/images/$1"
    },
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/manifest\\.webmanifest",
      "dest": "/manifest.webmanifest"
    },
    {
      "src": "/sw\\.js",
      "dest": "/sw.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
