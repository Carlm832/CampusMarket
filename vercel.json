{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "includeFiles": "{public/**,config/**,includes/**,pages/**,index.php,manifest.webmanifest,sw.js,robots.txt}"
    }
  },
  "routes": [
    {
      "src": "/public/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "dest": "/$1"
    },
    {
      "src": "/favicon\\.(ico|png)",
      "dest": "/images/logo.png"
    },
    {
      "src": "/(manifest\\.webmanifest|sw\\.js|robots\\.txt)",
      "dest": "/$1"
    },
    {
      "src": "/((?!public/|manifest\\.webmanifest|sw\\.js|favicon\\.|robots\\.txt).*)$",
      "dest": "/api/index.php"
    }
  ]
}
