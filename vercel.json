{
  "functions": {
    "index.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "pages/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "admin/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}
