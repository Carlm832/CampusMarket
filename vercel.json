{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "includeFiles": "**/*"
    },
    "api/web-push/send.js": {
      "maxDuration": 10
    },
    "api/stripe/webhook.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdn.vercel-insights.com https://vercel.live https://*.supabase.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https: http:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://cdn.vercel-insights.com https://vercel.live; frame-src 'self' https://js.stripe.com https://vercel.live; frame-ancestors 'none';"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/config/(.*)",
      "status": 403,
      "dest": "/api/index.php"
    },
    {
      "src": "/includes/(.*)",
      "status": 403,
      "dest": "/api/index.php"
    },
    {
      "src": "/database/(.*)",
      "status": 403,
      "dest": "/api/index.php"
    },
    {
      "src": "/public/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "dest": "/api/index.php"
    },
    {
      "src": "/favicon\\.(ico|png)",
      "dest": "/api/index.php"
    },
    {
      "src": "/(manifest\\.webmanifest|sw\\.js|robots\\.txt|sitemap\\.xml)",
      "dest": "/api/index.php"
    },
    {
      "src": "/api/web-push/send",
      "dest": "/api/web-push/send"
    },
    {
      "src": "/api/stripe/webhook",
      "dest": "/api/stripe/webhook"
    },
    {
      "src": "/((?!public/|manifest\\.webmanifest|sw\\.js|favicon\\.|robots\\.txt|sitemap\\.xml|api/web-push/|api/stripe/).*)$",
      "dest": "/api/index.php"
    }
  ]
}
